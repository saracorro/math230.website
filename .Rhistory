"Alpine"       = "#2293D1",
"McLaren"      = "#F58020",
"Alfa Romeo"   = "#C92D4B",
"Aston Martin" = "#358C75",
"Haas"         = "#B6BABD",
"AlphaTauri"   = "#5E8FAA",
"Williams"     = "#37BEDD"
)
Abu.Dhabi.Race$Driver <- reorder(Abu.Dhabi.Race$Driver, Abu.Dhabi.Race$Position, FUN = mean)
# Pace Consistency Ridge Plot
ggplot(Abu.Dhabi.Race, aes(x = `LapTime (s)`, y = Driver, fill = Driver)) +
geom_density_ridges(alpha = 0.7) +
theme_minimal() +
labs(title = "Pace Consistency Ridge Plot") +
theme(legend.position = "none")
# Average Race Position by Driver
avg_pos <- aggregate(Position ~ Driver, data = Abu.Dhabi.Race, mean)
ggplot(avg_pos, aes(x = reorder(Driver, Position), y = Position)) +
geom_bar(stat = "identity", fill = f1_palette[2]) + coord_flip() +
theme_minimal() + labs(title = "Mean Position by Driver", x="Driver")
# Average Race Position by Driver
avg_pos <- aggregate(Position ~ Driver, data = Abu.Dhabi.Race, mean)
ggplot(avg_pos, aes(x = reorder(Driver, Position), y = Position)) +
geom_bar(stat = "identity", fill = f1_palette[2]) + coord_flip() +
theme_minimal() + labs(title = "Mean Position by Driver", x="Driver")
# Race Position Bump Chart
ggplot(Abu.Dhabi.Race, aes(x = LapNumber, y = Position, color = Driver)) +
geom_line(size = 1) +
scale_y_reverse(breaks = 1:20) +
theme_minimal() +
theme(
legend.position = "bottom",
legend.text = element_text(size = 8),
legend.title = element_blank()
) +
guides(color = guide_legend(nrow = 2)) +
labs(title = "Race Position Bump Chart")
