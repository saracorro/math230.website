scale_y_reverse(breaks = 1:20) +
theme_minimal() +
theme(
legend.position = "bottom",
legend.text = element_text(size = 8),
legend.title = element_blank()
) +
guides(color = guide_legend(nrow = 2)) +
labs(title = "Race Position Bump Chart")
# Lap Number vs Lap Time
ggplot(Abu.Dhabi.Race, aes(x = LapNumber, y = `LapTime (s)`)) +
geom_point(color = f1_palette[1], alpha = 0.5) +
theme_minimal() + labs(title = "Lap Times Over Race Distance")
# Count of Laps per Tyre Compound
ggplot(Abu.Dhabi.Race, aes(x = Compound, fill = Compound)) +
geom_bar(color = "black") +
scale_fill_manual(values = c(
"SOFT"   = "#FF3333",
"MEDIUM" = "#FFFF33",
"HARD"   = "#FFFFFF"
)) +
theme_minimal() + labs(title = "Total Laps Run on Each Compound")
# Lap Times by Team
ggplot(Abu.Dhabi.Race, aes(x = Team, y = `LapTime (s)`, fill = Team)) +
geom_boxplot() + coord_flip() +
theme_minimal() + theme(legend.position = "none") +
labs(title = "Team Pace Distribution")
# Verstappen's Pace Profile
ggplot(subset(Abu.Dhabi.Race, Driver == "VER"), aes(x = LapNumber, y = `LapTime (s)`)) +
geom_line(color = f1_palette[5]) +
theme_minimal() + labs(title = "Verstappen Pace Profile")
# Histogram: Distribution of all Lap Times
ggplot(Abu.Dhabi.Race, aes(x = `LapTime (s)`)) +
geom_histogram(bins = 30, fill = f1_palette[3], color = "white") +
theme_minimal() + labs(title = "Overall Race Pace Distribution")
# Hamilton's Position
ggplot(subset(Abu.Dhabi.Race, Driver == "HAM"), aes(x = LapNumber, y = Position)) +
geom_step(color = f1_palette[1], linewidth = 1) + scale_y_reverse() +
theme_minimal() + labs(title = "Hamilton Position Tracking")
# Lap Times by Tyre Compound
ggplot(Abu.Dhabi.Race, aes(x = Compound, y = `LapTime (s)`, fill = Compound)) +
geom_boxplot() +
scale_fill_manual(values = c(
"SOFT"   = "#FF3333",
"MEDIUM" = "#FFFF33",
"HARD"   = "#FFFFFF"
)) +
theme_minimal() + labs(title = "Compound Performance Comparison")
# Lap Times colored by Team
ggplot(Abu.Dhabi.Race, aes(x = `LapTime (s)`, fill = Team)) +
geom_density(alpha = 0.25) +
theme_minimal() + labs(title = "Team Pace Density Overlap")
# Pit Stop Windows
ggplot(subset(Abu.Dhabi.Race, PitStop == TRUE), aes(x = LapNumber, y = Driver)) +
geom_point(color = f1_palette[2], size = 3) +
theme_minimal() + labs(title = "Pit Stop Strategy Windows")
# Total Pit Stops by Team
ggplot(subset(Abu.Dhabi.Race, PitStop == TRUE), aes(x = Team, fill = Team)) +
geom_bar() + theme_minimal() +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "none"
) +
labs(title = "Total Pit Stops by Team")
# Top 3 Drivers Comparison
ggplot(subset(Abu.Dhabi.Race, Position <= 3), aes(x = LapNumber, y = `LapTime (s)`, color = Driver)) +
geom_line() + theme_minimal() + labs(title = "Podium Pace Battle")
# Lap Times per Compound
ggplot(Abu.Dhabi.Race, aes(x = `LapTime (s)`, fill = Compound)) +
geom_histogram(bins = 20, color = "black") +
facet_wrap(~Compound) +
scale_fill_manual(values = c(
"SOFT"   = "#FF3333",
"MEDIUM" = "#FFFF33",
"HARD"   = "#FFFFFF"
)) +
theme_minimal() + labs(title = "Pace Distribution by Compound") +
theme(
axis.text.x = element_text(angle = 70, hjust = 1),
legend.position = "none"
)
# Pace Density Heatmap by Position
ggplot(Abu.Dhabi.Race, aes(x = Position, y = `LapTime (s)`)) +
stat_density_2d(aes(fill = ..level..), geom = "polygon") +
scale_fill_gradient(low = f1_palette[1], high = f1_palette[2]) +
geom_point(alpha = 0.1, size = 0.5, color = "white") +
scale_x_continuous(breaks = seq(1, 20, 1)) +
theme_minimal() +
labs(
title = "Pace Heatmap: Lap Time vs. Position",
fill = "Density")
