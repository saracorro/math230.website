# Calculate Mean and Standard Deviation for Team Pace
team_stats <- aggregate(`LapTime (s)` ~ Team,
data = Abu.Dhabi.Race,
FUN = function(x) c(Mean = mean(x, na.rm=TRUE),
SD = sd(x, na.rm=TRUE)))
# Flatten the result into a clean data frame
team_stats <- do.call(data.frame, team_stats)
colnames(team_stats) <- c("Team", "Avg_Pace", "Consistency_SD")
# Sort by fastest average pace
team_stats <- team_stats[order(team_stats$Avg_Pace), ]
print(head(team_stats, 5))
